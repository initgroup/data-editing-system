    {
      "owner": "*",
      "objectType": "PROCEDURE",
      "objectName": "INIT$_SP_DECISION_TREE_RULE_MODEL",
      "label": "M04_DECISION_TREE_RULE_모델생성",
      "description": "데이터 프로파일링 결과와 최종 분류값을 학습 데이터로 사용하여 의사결정트리 기반 규칙 모델을 생성하고, 컬럼 분류 규칙 요약을 만들기 위한 프로시저입니다.",
      "resultCreateYn": "M",
      "resultOwner": "__CURRENT_OWNER__",
      "resultTableName": "OML_DECISION_TREE_MODEL_01",
      "items": [
        {
          "key": "P_MODEL_NAME",
          "comment": "의사결정트리 규칙 모델명",
          "defaultValue": ":INIT$ResultModelName"
        },
        {
          "key": "P_DATA_QUERY",
          "comment": "학습 입력 데이터 SELECT 문",
          "defaultValue": "'SELECT CAST(R.OWNER || ''|'' || R.TABLE_NAME || ''|'' || R.MODEL_NAME || ''|'' || R.COLUMN_NAME AS VARCHAR2(4000)) AS CASE_ID, R.DATA_TYPE, R.TOTAL_ROWS, R.NUM_DISTINCT, R.DIST_VAL_RT, R.LOG_DATA_TYPE, R.ENTROPY, R.NORM_ENTROPY, COALESCE(F.FINAL_PREDICTED_TYPE, R.FINAL_PREDICTED_TYPE, R.MODL_PREDICTED_TYPE, R.BASE_PREDICTED_TYPE) AS TARGET_TYPE FROM (SELECT R.*, ROW_NUMBER() OVER (PARTITION BY R.OWNER, R.TABLE_NAME, R.MODEL_NAME, R.COLUMN_NAME ORDER BY R.RUN_ID DESC) AS RN FROM '||:INIT$TargetOwner||'.'||:INIT$TargetTable||' R WHERE R.RUN_SOURCE_TYPE = '''||:INIT$RunSourceType||''' AND ('''||:INIT$RunSourceType||''' <> ''FLOW_WORK'' OR R.RUN_ID = '||:INIT$RunId||')) R LEFT JOIN '||:INIT$TargetOwner||'.INIT$_TB_PREDICTED_TYPE_FINAL F ON F.OWNER = R.OWNER AND F.TABLE_NAME = R.TABLE_NAME AND F.COLUMN_NAME = R.COLUMN_NAME WHERE R.RN = 1 AND COALESCE(F.FINAL_PREDICTED_TYPE, R.FINAL_PREDICTED_TYPE, R.MODL_PREDICTED_TYPE, R.BASE_PREDICTED_TYPE) IS NOT NULL'"
        },
        {
          "key": "P_CASE_ID_COLUMN_NAME",
          "comment": "행 식별 컬럼명",
          "defaultValue": "CASE_ID"
        },
        {
          "key": "P_TARGET_COLUMN_NAME",
          "comment": "예측/분류 대상 컬럼명",
          "defaultValue": "TARGET_TYPE"
        },
        {
          "key": "P_CANDIDATE_COLUMNS",
          "comment": "학습 후보 컬럼 목록",
          "defaultValue": ""
        },
        {
          "key": "P_MIN_SUPPORT_COUNT",
          "comment": "규칙 생성 최소 건수",
          "defaultValue": "30"
        },
        {
          "key": "P_MIN_CONFIDENCE",
          "comment": "규칙 생성 최소 신뢰도",
          "defaultValue": "0.7"
        },
        {
          "key": "P_MIN_LIFT",
          "comment": "규칙 생성 최소 향상도",
          "defaultValue": "1"
        },
        {
          "key": "P_DROP_EXISTING_YN",
          "comment": "기존 동일 모델 삭제 여부",
          "defaultValue": "Y"
        },
        {
          "key": "P_MAX_INPUT_ROWS",
          "comment": "학습 입력 최대 행 수",
          "defaultValue": "100000"
        },
        {
          "key": "P_MAX_RULE_SUMMARY_COLUMNS",
          "comment": "규칙 요약 최대 컬럼 수",
          "defaultValue": "25"
        },
        {
          "key": "P_MAX_RULE_SUMMARY_PER_PAIR",
          "comment": "컬럼 쌍별 최대 요약 개수",
          "defaultValue": "50"
        },
        {
          "key": "P_TARGET_OWNER",
          "comment": "대상 테이블 계정",
          "defaultValue": ":INIT$TargetOwner"
        },
        {
          "key": "P_TARGET_TABLE",
          "comment": "대상 테이블명",
          "defaultValue": ":INIT$TargetTable"
        },
        {
          "key": "P_RUN_SOURCE_TYPE",
          "comment": "실행 출처 구분(DATA_WORK/FLOW_WORK)",
          "defaultValue": ":INIT$RunSourceType"
        },
        {
          "key": "P_RUN_ID",
          "comment": "실행 이력 ID",
          "defaultValue": ":INIT$RunId"
        }
      ]
    },
    {
      "owner": "*",
      "objectType": "PROCEDURE",
      "objectName": "INIT$_SP_RULE_VIOLATION_DETECT",
      "label": "M05_규칙위반탐지결과생성",
