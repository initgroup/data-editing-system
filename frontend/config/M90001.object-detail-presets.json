          "defaultValue": "500"
        },
        {
          "key": "P_MAX_VIOLATIONS_PER_RULE",
          "comment": "규칙별 최대 위반 건수",
          "defaultValue": "1000"
        },
        {
          "key": "P_CLEAR_EXISTING_YN",
          "comment": "기존 결과 삭제 여부",
          "defaultValue": "Y"
        },
        {
          "key": "P_COMMIT_YN",
          "comment": "프로시저 내부 커밋 여부",
          "defaultValue": "Y"
        },
        {
          "key": "P_RUN_SOURCE_TYPE",
          "comment": "실행 출처 구분(DATA_WORK/FLOW_WORK)",
          "defaultValue": ":INIT$RunSourceType"
        },
        {
          "key": "P_RUN_ID",
          "comment": "실행 이력 ID",
          "defaultValue": ":INIT$RunId"
        }
      ]
    },
    {
      "owner": "*",
