          "defaultValue": "FILE_ROW_NO"
        },
        {
          "key": "P_RESULT_OWNER",
          "comment": "결과 테이블 계정",
          "defaultValue": ":INIT$ResultOwner"
        },
        {
          "key": "P_RESULT_TABLE",
          "comment": "결과 테이블명",
          "defaultValue": ":INIT$ResultTable"
        },
        {
          "key": "P_MIN_CONFIDENCE",
          "comment": "위반 판단 최소 신뢰도",
          "defaultValue": "0.8"
        },
        {
          "key": "P_MIN_LIFT",
          "comment": "위반 판단 최소 향상도",
          "defaultValue": "1"
        },
        {
          "key": "P_MAX_RULES",
