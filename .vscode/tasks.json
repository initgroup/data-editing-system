{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "INIT Backup Source",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\backup-source.ps1",
                "-Mode",
                "${input:backupMode}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "INIT Backup Git Source",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\backup-source.ps1",
                "-Mode",
                "Git"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "INIT Backup Working Source",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\backup-source.ps1",
                "-Mode",
                "Working"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "backupMode",
            "type": "pickString",
            "description": "Choose backup mode",
            "options": [
                "Git",
                "Working"
            ],
            "default": "Git"
        }
    ]
}
