{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "INIT Backup Source",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\backup-source.ps1",
                "-Mode",
                "${input:backupMode}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "INIT Backup Git Source",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\backup-source.ps1",
                "-Mode",
                "Git"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "INIT Backup Working Source",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\backup-source.ps1",
                "-Mode",
                "Working"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Server",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoExit",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                ". '${workspaceFolder}\\venv\\Scripts\\Activate.ps1'; python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "backupMode",
            "type": "pickString",
            "description": "Choose backup mode",
            "options": [
                "Git",
                "Working"
            ],
            "default": "Git"
        }
    ]
}
