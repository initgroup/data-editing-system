# Copy this file to .env and fill in local values.
# Do not commit .env.

# local or cloud
DB_MODE=local

# Local Oracle DB
DB_USER_LOC=
DB_PASSWORD_LOC=
DB_HOST=127.0.0.1
DB_PORT=1521
DB_SERVICE=

# Oracle Cloud DB
DB_USER_CLD=
DB_PASSWORD_CLD=
DB_DSN_CLD=
DB_WALLET_PATH=secreats/Wallet_INITGROUPEDITING
DB_WALLET_PASSWORD=

# thin is recommended. Use thick only when Oracle Instant Client is required.
DB_ORACLE_MODE=thin
DB_CLIENT_PATH=

# Connection pool
DB_POOL_MIN=1
DB_POOL_MAX=5
DB_POOL_INCREMENT=1
TARGET_DB_POOL_MIN=1
TARGET_DB_POOL_MAX=3
TARGET_DB_POOL_INCREMENT=1

# Bootstrap/admin setup
INIT_BOOTSTRAP_SECRET=
INIT_ADMIN_KEY=

# Optional external API settings are usually stored through the app admin screens.
